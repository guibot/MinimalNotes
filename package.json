{
  "name": "context-note",
  "version": "1.0.0",
  "description": "Minimal always-available personal context note",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "devDependencies": {
    "electron": "^28.3.3",
    "electron-builder": "^24.0.0"
  },
  "build": {
    "appId": "com.personal.context-note",
    "productName": "MinimalNotes",
    "icon": "icon.ico",
    "files": [
      "main.js",
      "preload.js",
      "index.html",
      "icon.png",
      "icon.ico"
    ],
    "mac": {
      "target": "dmg",
      "category": "public.app-category.productivity"
    },
    "linux": {
      "target": "AppImage",
      "category": "Utility"
    },
    "win": {
      "target": "nsis",
      "icon": "icon.ico"
    }
  }
}
